ADMIN_USERNAME=admin
ADMIN_PASSWORD=ADMIN1234!
ADMIN_DISPLAY_NAME=관리자
MANAGER_USERNAME=manager
MANAGER_PASSWORD=MANAGER1234!
MANAGER_DISPLAY_NAME=매니저

