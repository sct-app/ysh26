PORT=3000
NODE_ENV=development

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ysh26

# JWT secret (long random string)
JWT_SECRET=change_this_to_long_random_secret

# Allowed frontend origin(s), comma-separated
# Example: http://localhost:5500,https://<username>.github.io
FRONTEND_ORIGIN=http://localhost:5500

# Cookie options
# For cross-site cookie (GitHub Pages -> API), use:
# COOKIE_SAMESITE=None
# COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
COOKIE_SECURE=false

# Seed defaults (change in production)
